# ─── Site Configuration ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://convertnow.ca

# ─── Google Analytics 4 ────────────────────────────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google AdSense ────────────────────────────────────────────────
# Get from: https://adsense.google.com → Account → Publisher ID
NEXT_PUBLIC_ADSENSE_ID=ca-pub-7999532935872277

# ─── AdSense Ad Slot IDs ───────────────────────────────────────────
# Get from: AdSense → Ads → By Ad Unit → create each unit
NEXT_PUBLIC_AD_SLOT_HEADER=1234567890
NEXT_PUBLIC_AD_SLOT_SIDEBAR_TOP=2345678901
NEXT_PUBLIC_AD_SLOT_SIDEBAR_BOTTOM=3456789012
NEXT_PUBLIC_AD_SLOT_IN_CONTENT=4567890123
NEXT_PUBLIC_AD_SLOT_FOOTER=5678901234
NEXT_PUBLIC_AD_SLOT_MOBILE=6789012345

# ─── Google Search Console ─────────────────────────────────────────
# Get from: Search Console → Settings → Ownership Verification → HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# ─── Microsoft Clarity ─────────────────────────────────────────────
# Get from: https://clarity.microsoft.com → New Project → ID
NEXT_PUBLIC_CLARITY_ID=your-clarity-id

# ─── Exchange Rate API (optional — fallback rates built-in) ────────
# Free tier available at: https://exchangerate-api.com
EXCHANGE_RATE_API_KEY=your-api-key-here
