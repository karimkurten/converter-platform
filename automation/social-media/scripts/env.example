# ConvertNow.ca Social Media Automation - Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED: OpenRouter (text + image generation) ===
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === REQUIRED for push_to_sheets.py: Google Cloud ===
# Create at: https://console.cloud.google.com/
GOOGLE_SHEET_ID=your-sheet-id-from-url
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-from-url

# Path to service account JSON file (relative to scripts/ folder)
GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json

# === OPTIONAL: Backup admin email ===
ADMIN_EMAIL=your-email@example.com
